# Example dbt profile for zero_one_games.
#
# Copy values into your real ~/.dbt/profiles.yml (or keep this profiles.yml in
# the project root) and provide secrets via environment variables — DO NOT paste
# a service-account key path or any secret into a committed file.
#
# Required environment variables
# ------------------------------
#   DBT_GOOGLE_KEYFILE     Absolute path to a BigQuery service-account JSON key
#                          (or leave unset and use Application Default
#                          Credentials / Workload Identity Federation in CI).
#   DBT_PII_SALT           Salt used by macros/mask_pii.sql to hash PII. Keep it
#                          secret and stable across runs.
#
# Optional (sensible defaults are baked into profiles.yml)
# -------------------------------------------------------
#   DBT_BIGQUERY_PROJECT   GCP project id      (default: chef-master-8f916)
#   DBT_BIGQUERY_DATASET   Target dataset      (dev: dbt_<you>, prod: analytics)
#   DBT_BIGQUERY_LOCATION  BigQuery location   (default: EU)
#
# PowerShell (current session):
#   $env:DBT_GOOGLE_KEYFILE = "C:\path\to\key.json"
#   $env:DBT_PII_SALT       = "a-long-random-string"
#
# bash/zsh:
#   export DBT_GOOGLE_KEYFILE="/path/to/key.json"
#   export DBT_PII_SALT="a-long-random-string"

default:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      keyfile: "{{ env_var('DBT_GOOGLE_KEYFILE') }}"
      project: "{{ env_var('DBT_BIGQUERY_PROJECT', 'chef-master-8f916') }}"
      dataset: "{{ env_var('DBT_BIGQUERY_DATASET', 'dbt_dev') }}"
      location: "{{ env_var('DBT_BIGQUERY_LOCATION', 'EU') }}"
      threads: 16
      priority: interactive
